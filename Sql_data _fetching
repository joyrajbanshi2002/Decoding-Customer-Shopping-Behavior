#Fetching Data by SQl and explaing all the steps

1.

select gender, SUM(purchase_amount) as revenue
from customer
group by gender

#SELECT gender → Retrieves the gender column.
SUM(purchase_amount) → Adds all purchase amounts to calculate total revenue.
AS revenue → Renames the calculated column as revenue.
FROM customer → Uses data from the customer table.
GROUP BY gender → Groups the data by gender so revenue is calculated separately for each gender.

2.

select customer_id, purchase_amount 
from customer 
where discount_applied = 'Yes' and purchase_amount >= (select AVG(purchase_amount) from customer)

#SELECT customer_id, purchase_amount → Retrieves customer ID and their purchase amount.
FROM customer → Uses the customer table.
discount_applied = 'Yes' → Filters customers who used a discount.
AVG(purchase_amount) → Calculates the average purchase amount of all customers.
purchase_amount >= (...) → Returns customers whose spending is greater than or equal to the average.

3.

select item_purchased, round(avg(review_rating::numeric),2) as "Average Product Rating"
from customer
group by item_purchased
order by avg(review_rating) desc
limit 5

#SELECT item_purchased → Retrieves the product names.
AVG(review_rating::numeric) → Calculates the average review rating for each product.
review_rating::numeric → Converts the review rating into numeric format for calculation.
ROUND(..., 2) → Rounds the average rating to 2 decimal places.
AS "Average Product Rating" → Renames the output column.
GROUP BY item_purchased → Groups records by product.
ORDER BY AVG(review_rating) DESC → Sorts products from highest to lowest rating.
LIMIT 5 → Displays only the top 5 products.

4.

select shipping_type, 
ROUND(AVG(purchase_amount),2)
from customer
where shipping_type in ('Standard','Express')

#group by shipping_tySELECT shipping_type → Retrieves the shipping method.
AVG(purchase_amount) → Calculates the average purchase amount for each shipping type.
ROUND(..., 2) → Rounds the result to 2 decimal places.
WHERE shipping_type IN ('Standard', 'Express') → Filters only Standard and Express shipping records.
GROUP BY shipping_type → Groups the data based on shipping type.pe;

5.

SELECT subscription_status,
       COUNT(customer_id) AS total_customers,
       ROUND(AVG(purchase_amount),2) AS avg_spend,
       ROUND(SUM(purchase_amount),2) AS total_revenue

#subscription_status → Displays whether the customer is a subscriber or non-subscriber.
COUNT(customer_id) → Counts the total number of customers in each subscription group.
AVG(purchase_amount) → Calculates the average spending per customer.
SUM(purchase_amount) → Calculates total revenue generated.
ROUND(..., 2) → Rounds numerical values to 2 decimal places.
GROUP BY subscription_status → Groups the analysis based on subscription type.

6.

SELECT item_purchased,
       ROUND(100.0 * SUM(CASE WHEN discount_applied = 'Yes' THEN 1 ELSE 0 END)/COUNT(*),2) AS discount_rate
FROM customer
GROUP BY item_purchased
ORDER BY discount_rate DESC
LIMIT 5;

#item_purchased → Displays the product name.
CASE WHEN discount_applied = 'Yes' THEN 1 ELSE 0 END → Counts discounted purchases.
SUM(...) → Adds all discounted purchase counts.
COUNT(*) → Counts total purchases for each product.
100.0 * ... / COUNT(*) → Calculates the percentage of discounted purchases.
ROUND(..., 2) → Rounds the percentage to 2 decimal places.
GROUP BY item_purchased → Groups data by product.
ORDER BY discount_rate DESC → Sorts products from highest to lowest discount usage.
LIMIT 5 → Returns only the top 5 products.

7.

with customer_type as (
SELECT customer_id, previous_purchases,
CASE 
    WHEN previous_purchases = 1 THEN 'New'
    WHEN previous_purchases BETWEEN 2 AND 10 THEN 'Returning'
    ELSE 'Loyal'
    END AS customer_segment
FROM customer)

select customer_segment,count(*) AS "Number of Customers" 
from customer_type 
group by customer_segment;

#WITH customer_type AS (...) → Creates a Common Table Expression (CTE) to classify customers.
CASE statement → Categorizes customers based on purchase history:
New → Customers with 1 previous purchase.
Returning → Customers with 2 to 10 previous purchases.
Loyal → Customers with more than 10 previous purchases.
COUNT(*) → Counts the number of customers in each segment.
GROUP BY customer_segment → Groups the results by customer category.

8.

WITH item_counts AS (
    SELECT category,
           item_purchased,
           COUNT(customer_id) AS total_orders,
           ROW_NUMBER() OVER (PARTITION BY category ORDER BY COUNT(customer_id) DESC) AS item_rank
    FROM customer
    GROUP BY category, item_purchased
)
SELECT item_rank,category, item_purchased, total_orders
FROM item_counts
WHERE item_rank <=3;

#WITH item_counts AS (...) → Creates a Common Table Expression (CTE) to calculate product rankings within each category.
COUNT(customer_id) → Counts the number of orders for each product.
ROW_NUMBER() OVER (...) → Assigns a rank to products within each category.
PARTITION BY category → Separates ranking for each category individually.
ORDER BY COUNT(customer_id) DESC → Ranks products from highest to lowest orders.
GROUP BY category, item_purchased → Groups data by category and product name.
WHERE item_rank <= 3 → Returns only the top 3 products from each category.

9.

SELECT subscription_status,
       COUNT(customer_id) AS repeat_buyers
FROM customer
WHERE previous_purchases > 5
GROUP BY subscription_status;

#subscription_status → Displays whether the customer is a subscriber or non-subscriber.
COUNT(customer_id) → Counts the number of repeat buyers in each subscription group.
WHERE previous_purchases > 5 → Filters customers who made more than 5 purchases.
GROUP BY subscription_status → Groups the results based on subscription type.

10.

SELECT 
    age_group,
    SUM(purchase_amount) AS total_revenue
FROM customer
GROUP BY age_group
ORDER BY total_revenue desc;

#age_group → Displays customer age categories.
SUM(purchase_amount) → Calculates the total revenue generated by each age group.
AS total_revenue → Renames the calculated column for better readability.
GROUP BY age_group → Groups customers based on age groups.
ORDER BY total_revenue DESC → Sorts age groups from highest to lowest revenue contribution.

